#!/usr/bin/expect -f

set timeout 10

spawn make run

expect "ynix> "
send "help\r"

expect "Ynix Shell Commands:"
expect "ynix> "

send "ls\r"
expect "Docs/"
expect "ynix> "

send "cat Docs/honest_review.md\r"
expect "Honest Review of Ynix"
expect "ynix> "

send "\x01\x78" ;# Send Ctrl-A X to exit QEMU if needed, or simply let timeout kill it.
exit 0
