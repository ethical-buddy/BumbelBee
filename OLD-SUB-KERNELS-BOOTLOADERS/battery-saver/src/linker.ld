OUTPUT_FORMAT("binary")
ENTRY(_start)

SECTIONS
{
    /* The kernel is loaded at 0x100000 by the bootloader */
    . = 0x100000;

    .text ALIGN(4K) :
    {
        *(.text*)
    }

    .rodata ALIGN(4K) :
    {
        *(.rodata*)
    }

    .data ALIGN(4K) :
    {
        *(.data*)
    }

    .bss ALIGN(4K) :
    {
        *(COMMON)
        *(.bss*)
    }
}
